# Vision provider: "dify" (default) or "anthropic"
VISION_PROVIDER=dify

# Dify Cloud
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=

# Anthropic (VISION_PROVIDER=anthropic のとき使用)
ANTHROPIC_API_KEY=

# STG環境認証 (省略時はURLに直接アクセス)
BASE_URL=
BASIC_USER=
BASIC_PASS=

# perman認証セレクタ
PERMAN_MODAL_SELECTOR=
PERMAN_USERNAME_SELECTOR=
PERMAN_PASSWORD_SELECTOR=
PERMAN_SUBMIT_SELECTOR=

# アプリログイン
APP_USER=
APP_PASS=
LOGIN_ENTRY_TEXT=
LOGIN_ACCOUNT_TEXT=
LOGIN_PROVIDER_TEXT=
LOGIN_EMAIL_LABEL=
LOGIN_PASSWORD_LABEL=
LOGIN_SUBMIT_TEXT=

# HAR取得対象ドメイン（カンマ区切り）
ALLOW_LIST=
